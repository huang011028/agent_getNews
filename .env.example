# ===== AI 模型 API（用于总结/语义过滤）=====
# 使用 DeepSeek V4 Pro（OpenAI 兼容接口）
# API Key 从 https://platform.deepseek.com 申请
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# DeepSeek 官方 base_url（OpenAI 兼容）
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# ===== 邮件 SMTP 配置 =====
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_account@qq.com
# 邮箱授权码（非登录密码）
SMTP_PASS=your_smtp_authorization_code
# 发件人显示名
MAIL_FROM_NAME=每日AI速报
# 收件人，多个用英文逗号分隔
MAIL_TO=receiver1@example.com,receiver2@example.com